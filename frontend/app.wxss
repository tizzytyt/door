/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
  /* 预留 tabBar + 安全区，避免底部按钮被遮挡 */
  padding-bottom: calc(30rpx + 160rpx + env(safe-area-inset-bottom));
}

.btn-primary {
  background-color: #007aff;
  color: #ffffff;
  border-radius: 10rpx;
}

.btn-primary:active {
  opacity: 0.8;
}
