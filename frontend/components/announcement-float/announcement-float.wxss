.float-wrap {
  position: fixed;
  right: 24rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  max-width: 280rpx;
}

.float-wrap--tab {
  bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.float-inner {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #007aff 0%, #0056b3 100%);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.35);
}

.float-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  line-height: 44rpx;
  text-align: center;
}

.float-text {
  display: flex;
  flex-direction: column;
}

.float-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
  line-height: 1.2;
}

.float-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.float-dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  background: #ff3b30;
  border-radius: 18rpx;
  border: 3rpx solid #fff;
  box-sizing: border-box;
}
