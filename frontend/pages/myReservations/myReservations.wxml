<view class="page-with-float">
<view class="container">
  <!-- 顶部标签栏 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === -1 ? 'active' : ''}}" bindtap="switchTab" data-status="-1">全部</view>
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-status="0">待审核</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-status="1">已通过</view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-status="2">已拒绝</view>
    <view class="tab-item {{currentTab === 3 ? 'active' : ''}}" bindtap="switchTab" data-status="3">已使用</view>
    <view class="tab-item calendar-tab" bindtap="navToCalendar">日历</view>
  </view>

  <!-- 预约列表 -->
  <scroll-view scroll-y class="list-scroll" enable-back-to-top>
    <view class="list-content">
      <block wx:if="{{filteredList.length > 0}}">
        <view class="reservation-card" wx:for="{{filteredList}}" wx:key="id" bindtap="navToDetail" data-id="{{item.id}}">
          <view class="card-header">
            <text class="device-name">{{item.deviceName}}</text>
            <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
          </view>
          <view class="card-body">
            <view class="info-row">
              <text class="label">日期：</text>
              <text class="value">{{item.reservationDate}}</text>
            </view>
            <view class="info-row">
              <text class="label">时间：</text>
              <text class="value">{{item.startTime}} - {{item.endTime}}</text>
            </view>
            <view class="info-row">
              <text class="label">事由：</text>
              <text class="value">{{item.reason}}</text>
            </view>
          </view>
          <view class="card-footer" catchtap="stopProp">
            <button class="btn-cancel" size="mini" wx:if="{{item.status === 0}}" bindtap="handleCancel" data-id="{{item.id}}">取消申请</button>
            <button class="btn-use" size="mini" wx:if="{{item.status === 1}}" bindtap="handleUse" data-id="{{item.id}}">确认使用</button>
          </view>
        </view>
      </block>
      <view class="empty-tip" wx:else>
        <text>暂无预约记录</text>
      </view>
    </view>
  </scroll-view>
</view>
  <announcement-float />
</view>
