.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid #f3f3f3;
}

.form-item-textarea {
  align-items: flex-start;
}

.label {
  width: 150rpx;
  color: #666;
  font-size: 26rpx;
}

.picker-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 0;
}

.textarea {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  min-height: 120rpx;
  padding: 10rpx 0;
}

.btn-submit {
  margin-top: 18rpx;
  background: #007aff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 10rpx 0 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  font-size: 22rpx;
  color: #666;
  padding: 6rpx 12rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 1px solid #eee;
}

.tab.active {
  color: #007aff;
  border-color: rgba(0,122,255,0.35);
  background: rgba(0,122,255,0.08);
}

.list-scroll {
  max-height: calc(100vh - 520rpx);
}

.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.left {
  display: flex;
  flex-direction: column;
}

.type {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.time {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-0 { color: #F2994A; background: #FFF7E6; }
.status-1 { color: #11998e; background: #e0fcf4; }
.status-2 { color: #ff4d4f; background: #fff1f0; }
.status-3 { color: #999; background: #f5f5f5; }

.row {
  display: flex;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.row-label {
  width: 90rpx;
  color: #999;
}

.row-value {
  flex: 1;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1px solid #f3f3f3;
}

.btn-cancel {
  background: #fff;
  color: #666;
  border: 1px solid #ddd;
  font-size: 24rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}
