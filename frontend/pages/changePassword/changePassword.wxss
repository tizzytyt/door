.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid #f3f3f3;
}

.label {
  width: 150rpx;
  color: #666;
  font-size: 26rpx;
}

.input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 0;
}

.btn-submit {
  margin-top: 18rpx;
  background: #007aff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.hint {
  margin-top: 14rpx;
  color: #999;
  font-size: 22rpx;
}

