<view class="page-with-float">
<view class="container">
  <view class="card">
    <view class="title">修改密码</view>

    <view class="form-item">
      <text class="label">旧密码</text>
      <input class="input" password placeholder="请输入旧密码" value="{{oldPassword}}" data-field="oldPassword" bindinput="handleInput" />
    </view>

    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" password placeholder="请输入新密码（至少6位）" value="{{newPassword}}" data-field="newPassword" bindinput="handleInput" />
    </view>

    <view class="form-item">
      <text class="label">确认</text>
      <input class="input" password placeholder="请再次输入新密码" value="{{confirmPassword}}" data-field="confirmPassword" bindinput="handleInput" />
    </view>

    <button class="btn-submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleSubmit">确认修改</button>
    <view class="hint">修改成功后将退出登录，请使用新密码重新登录。</view>
  </view>
</view>
  <announcement-float />
</view>

