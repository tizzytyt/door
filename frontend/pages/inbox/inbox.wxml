<view class="page-with-float">
<view class="container">
  <view class="section-tip">以下为预约审核结果与开始前提醒；系统公告请从下方入口查看。</view>

  <view class="entry-card" bindtap="goAnnouncements">
    <view class="entry-left">
      <text class="entry-title">系统公告</text>
      <text class="entry-sub">管理员发布的通知</text>
    </view>
    <view class="entry-right">
      <view class="badge" wx:if="{{announcementUnread > 0}}">
        <text class="badge-text">未读 {{announcementUnread}}</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="header">
    <text class="title">预约消息</text>
    <view class="right">
      <view class="badge" wx:if="{{reservationUnread > 0}}">
        <text class="badge-text">未读 {{reservationUnread}}</text>
      </view>
      <button class="btn-mini" size="mini" bindtap="loadAll">刷新</button>
    </view>
  </view>

  <scroll-view scroll-y class="list-scroll">
    <view class="list-content">
      <block wx:if="{{list.length > 0}}">
        <view class="card" wx:for="{{list}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
          <view class="row">
            <view class="left">
              <view class="title-row">
                <view class="dot" wx:if="{{item.isRead === 0}}"></view>
                <text class="card-title">{{item.title}}</text>
              </view>
              <text class="meta">
                <text class="type-tag type-{{item.type}}">{{item.typeText}}</text>
                <text class="time">{{item.createdAtText}}</text>
              </text>
            </view>
            <text class="status {{item.isRead === 1 ? 'read' : 'unread'}}">{{item.isRead === 1 ? '已读' : '未读'}}</text>
          </view>
          <text class="preview">{{item.preview}}</text>
        </view>
      </block>
      <view class="empty" wx:else>暂无预约类消息</view>
    </view>
  </scroll-view>
</view>
<announcement-float />
</view>
