<view class="container">
  <view class="top-card">
    <view class="search-row">
      <input
        class="search-input"
        placeholder="搜索门禁名称/位置"
        value="{{keyword}}"
        bindinput="handleSearchInput"
      />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="clearSearch">清除</text>
    </view>
    <view class="summary">
      <text>共 {{list.length}} 个收藏</text>
      <text wx:if="{{keyword}}">，匹配 {{filteredList.length}} 个</text>
    </view>
  </view>

  <scroll-view scroll-y class="list-scroll">
    <view class="list-content">
      <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
      <block wx:if="{{!loading && filteredList.length > 0}}">
        <view class="favorite-card" wx:for="{{filteredList}}" wx:key="deviceId">
          <view class="card-header">
            <view class="left">
              <text class="device-name">{{item.deviceName}}</text>
              <text class="device-loc">{{item.location}}</text>
            </view>
          </view>
          <view class="card-footer">
            <button class="btn-reserve" size="mini" bindtap="handleReserve" data-id="{{item.deviceId}}" data-name="{{item.deviceName}}">预约</button>
            <button class="btn-remove" size="mini" bindtap="handleRemove" data-id="{{item.deviceId}}">移除</button>
          </view>
        </view>
      </block>
      <view class="empty-tip" wx:if="{{!loading && filteredList.length === 0}}">
        <text>暂无收藏的门禁</text>
      </view>
    </view>
  </scroll-view>
</view>
