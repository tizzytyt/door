<view class="container">
  <view class="login-box">
    <view class="title">欢迎注册门禁预约系统</view>

    <view class="form-item">
      <text class="label">账号</text>
      <input class="input" type="text" model:value="{{username}}" placeholder="请输入学号/工号" />
    </view>

    <view class="form-item">
      <text class="label">真实姓名</text>
      <input class="input" type="text" model:value="{{realName}}" placeholder="请输入真实姓名" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="text" model:value="{{phone}}" placeholder="请输入手机号（可选）" />
    </view>

    <view class="form-item">
      <text class="label">身份</text>
      <radio-group class="radio-group" bindchange="handleRoleChange">
        <label class="radio">
          <radio value="student" checked="{{role === 'student'}}" color="#007aff" />学生
        </label>
        <label class="radio">
          <radio value="admin" checked="{{role === 'admin'}}" color="#007aff" />管理员
        </label>
        <label class="radio">
          <radio value="super_admin" checked="{{role === 'super_admin'}}" color="#007aff" />超管
        </label>
      </radio-group>
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" type="password" model:value="{{password}}" placeholder="请输入密码（至少6位）" />
    </view>

    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="input" type="password" model:value="{{confirmPassword}}" placeholder="请再次输入密码" />
    </view>

    <button class="btn-primary" loading="{{loading}}" bindtap="handleRegister">注册</button>

    <view class="bottom">
      <text class="link" bindtap="goLogin">已有账号？去登录</text>
    </view>
  </view>
</view>

