<view class="container">
  <view class="login-box">
    <view class="title">欢迎注册门禁预约系统</view>
    <view class="subtitle">本页仅供学生/普通用户注册；管理员账号由超级管理员在管理后台创建。</view>

    <view class="form-item">
      <text class="label">账号</text>
      <input class="input" type="text" model:value="{{username}}" placeholder="请输入学号/工号" />
    </view>

    <view class="form-item">
      <text class="label">真实姓名</text>
      <input class="input" type="text" model:value="{{realName}}" placeholder="请输入真实姓名" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" model:value="{{phone}}" placeholder="请输入手机号（可选，11位）" />
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" type="password" model:value="{{password}}" placeholder="请输入密码（至少6位）" />
    </view>

    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="input" type="password" model:value="{{confirmPassword}}" placeholder="请再次输入密码" />
    </view>

    <button class="btn-primary" loading="{{loading}}" bindtap="handleRegister">注册</button>

    <view class="bottom">
      <text class="link" bindtap="goLogin">已有账号？去登录</text>
    </view>
  </view>
</view>

