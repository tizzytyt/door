.container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #f5f5f5;
}

.login-box {
  width: 80%;
  background-color: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 60rpx;
  color: #333;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1px solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.radio-group {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
}

.radio {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.radio radio {
  transform: scale(0.8);
  margin-right: 6rpx;
}

.btn-primary {
  margin-top: 60rpx;
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #007aff;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 0;
}

.bottom {
  margin-top: 30rpx;
  text-align: center;
}

.link {
  font-size: 26rpx;
  color: #007aff;
}

