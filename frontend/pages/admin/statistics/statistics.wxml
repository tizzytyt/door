<view class="container">
  <view class="card">
    <view class="title-row">
      <view class="title">核心指标</view>
      <button class="btn-export" size="mini" bindtap="exportExcel">导出Excel</button>
    </view>
    <view class="metrics">
      <view class="metric">
        <text class="num">{{stats.totalReservations}}</text>
        <text class="label">总预约</text>
      </view>
      <view class="metric">
        <text class="num">{{stats.pendingCount}}</text>
        <text class="label">待审核</text>
      </view>
      <view class="metric">
        <text class="num">{{stats.successCount}}</text>
        <text class="label">成功(通过+已用)</text>
      </view>
      <view class="metric">
        <text class="num">{{stats.deviceCount}}</text>
        <text class="label">设备数</text>
      </view>
      <view class="metric">
        <text class="num">{{stats.userCount}}</text>
        <text class="label">用户数</text>
      </view>
      <view class="metric">
        <text class="num">{{stats.successRate}}%</text>
        <text class="label">成功率</text>
      </view>
    </view>
    <view class="hint">成功率口径：成功 / 总预约</view>
  </view>

  <view class="card">
    <view class="title">占比概览</view>
    <view class="row">
      <text class="row-label">待审核占比</text>
      <view class="bar">
        <view class="bar-fill bar-pending" style="width: {{stats.pendingRate}}%;"></view>
      </view>
      <text class="row-num">{{stats.pendingRate}}%</text>
    </view>
    <view class="row">
      <text class="row-label">成功占比</text>
      <view class="bar">
        <view class="bar-fill bar-success" style="width: {{stats.successRate}}%;"></view>
      </view>
      <text class="row-num">{{stats.successRate}}%</text>
    </view>
    <view class="hint">下拉可刷新统计数据</view>
  </view>

  <view class="card">
    <view class="title">近7天预约量</view>
    <block wx:for="{{trend7}}" wx:key="date">
      <view class="row">
        <text class="row-label">{{item.shortDate}}</text>
        <view class="bar">
          <view class="bar-fill bar-trend" style="width: {{(item.count * 100 / trend7Max)}}%;"></view>
        </view>
        <text class="row-num">{{item.count}}</text>
      </view>
    </block>
    <view class="hint">按预约日期聚合</view>
  </view>

  <view class="card">
    <view class="title">状态分布</view>
    <block wx:for="{{statusDistList}}" wx:key="status">
      <view class="row">
        <text class="row-label">{{item.label}}</text>
        <view class="bar">
          <view class="bar-fill bar-status" style="width: {{(item.count * 100 / statusDistMax)}}%;"></view>
        </view>
        <text class="row-num">{{item.count}}</text>
      </view>
    </block>
    <view class="hint">口径：预约单状态（0-5）</view>
  </view>

  <view class="card">
    <view class="title">门禁 Top5</view>
    <block wx:if="{{topDevices.length>0}}">
      <block wx:for="{{topDevices}}" wx:key="name">
        <view class="row">
          <text class="row-label">{{index + 1}}. {{item.name}}</text>
          <view class="bar">
            <view class="bar-fill bar-top" style="width: {{(item.count * 100 / topDevicesMax)}}%;"></view>
          </view>
          <text class="row-num">{{item.count}}</text>
        </view>
      </block>
    </block>
    <view class="empty-top" wx:else>暂无数据</view>
  </view>

  <view class="card">
    <view class="title-row">
      <view class="title">在校人员</view>
      <view class="inside-actions">
        <view class="inside-switch">
          <text class="inside-switch-text">仅当前在校</text>
          <switch checked="{{insideOnly}}" bindchange="onInsideOnlyChange" />
        </view>
        <button class="btn-export" size="mini" bindtap="exportInsideExcel">导出Excel</button>
      </view>
    </view>

    <block wx:if="{{insideOnly}}">
      <view class="inside-header">
        <text class="inside-col inside-col-name">角色姓名</text>
        <text class="inside-col inside-col-time">预约时间段</text>
      </view>

      <block wx:if="{{insideList.length>0}}">
        <block wx:for="{{insideList}}" wx:key="id">
          <view class="inside-row">
            <text class="inside-col inside-col-name">{{item.roleText}}{{item.realName}}</text>
            <text class="inside-col inside-col-time">{{item.reservationTimeText}}</text>
          </view>
        </block>
      </block>
      <view class="empty-top" wx:else>暂无在校人员</view>
    </block>
  </view>

  <view class="footer">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:else>更新时间：{{updatedAt}}</text>
  </view>
</view>