.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.top-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  background: #f5f6f7;
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}

.clear-btn {
  color: #007aff;
  font-size: 24rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  font-size: 22rpx;
  color: #666;
  padding: 6rpx 14rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 1px solid #eee;
}

.tab.active {
  color: #007aff;
  border-color: rgba(0,122,255,0.35);
  background: rgba(0,122,255,0.08);
}

.btn-add {
  background: #007aff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
  padding: 0 22rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.summary-row {
  margin-top: 12rpx;
  color: #999;
  font-size: 22rpx;
  display: flex;
  justify-content: space-between;
}

.list-scroll {
  max-height: calc(100vh - 280rpx);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.left {
  display: flex;
  flex-direction: column;
  max-width: 520rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-1 { color: #11998e; background: #e0fcf4; } /* 正常 */
.status-2 { color: #F2994A; background: #FFF7E6; } /* 维护 */
.status-0 { color: #ff4d4f; background: #fff1f0; } /* 故障 */

.desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1px solid #f3f3f3;
}

.btn-edit {
  background: rgba(0,122,255,0.10);
  color: #007aff;
  border: 1px solid rgba(0,122,255,0.22);
  font-size: 24rpx;
}

.btn-del {
  background: rgba(255,77,79,0.10);
  color: #ff4d4f;
  border: 1px solid rgba(255,77,79,0.22);
  font-size: 24rpx;
}

.loading-tip {
  text-align: center;
  color: #999;
  padding: 20rpx 0;
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* 弹窗表单 */
.mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.sheet {
  width: 100%;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 24rpx;
  box-sizing: border-box;
  max-height: 80vh;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid #f3f3f3;
}

.label {
  width: 150rpx;
  color: #666;
  font-size: 26rpx;
}

.input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 0;
}

.picker-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 0;
}

.textarea {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  min-height: 100rpx;
  padding: 10rpx 0;
}

.sheet-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.btn-save {
  flex: 1;
  background: #007aff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.btn-cancel {
  width: 200rpx;
  background: #fff;
  color: #666;
  border: 1px solid #ddd;
  border-radius: 14rpx;
  font-size: 26rpx;
}

