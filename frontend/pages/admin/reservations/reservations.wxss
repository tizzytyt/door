.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.top-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  background: #f5f6f7;
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}

.clear-btn {
  color: #007aff;
  font-size: 24rpx;
}

.filters {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.chip {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 14rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 1px solid #eee;
}

.chip.active {
  color: #007aff;
  border-color: rgba(0,122,255,0.35);
  background: rgba(0,122,255,0.08);
}

.picker-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.summary-row {
  margin-top: 12rpx;
  color: #999;
  font-size: 22rpx;
  display: flex;
  justify-content: space-between;
}

.list-scroll {
  max-height: calc(100vh - 300rpx);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.left {
  display: flex;
  flex-direction: column;
  max-width: 520rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-0 { color: #F2994A; background: #FFF7E6; }
.status-1 { color: #11998e; background: #e0fcf4; }
.status-2 { color: #ff4d4f; background: #fff1f0; }
.status-3 { color: #999; background: #f5f5f5; }
.status-4 { color: #999; background: #f5f5f5; }
.status-5 { color: #999; background: #f5f5f5; }

.row {
  display: flex;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.row-label {
  width: 90rpx;
  color: #999;
}

.row-value {
  flex: 1;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-tip {
  text-align: center;
  color: #999;
  padding: 20rpx 0;
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}

