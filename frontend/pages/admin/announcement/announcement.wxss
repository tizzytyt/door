.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid #f3f3f3;
}

.form-item-textarea {
  align-items: flex-start;
}

.label {
  width: 150rpx;
  color: #666;
  font-size: 26rpx;
}

.input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 0;
}

.textarea {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  min-height: 140rpx;
  padding: 10rpx 0;
}

.form-hint {
  margin-top: 12rpx;
  color: #999;
  font-size: 22rpx;
}

.actions {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.btn-primary {
  flex: 1;
  background: #007aff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.btn-secondary {
  flex: 1;
  background: #f2f2f7;
  color: #333;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.list-section {
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 10rpx 0 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.btn-mini {
  background: rgba(0,122,255,0.08);
  color: #007aff;
  border: 1px solid rgba(0,122,255,0.25);
  border-radius: 999rpx;
  font-size: 22rpx;
}

.list-scroll {
  max-height: calc(100vh - 520rpx);
}

.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 18rpx;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.left {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  max-width: 520rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  display: block;
}

.stats {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: flex-end;
}

.stat {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.stat.read {
  color: #34c759;
  background: rgba(52, 199, 89, 0.10);
}

.stat.unread {
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.10);
}

.item-preview {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
}

.btn-action {
  background-color: #007aff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.btn-danger {
  background-color: #ff3b30;
  color: #fff;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 26rpx;
}

