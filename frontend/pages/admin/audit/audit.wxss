.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.top-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: #f5f6f7;
}

.tab.active {
  color: #fff;
  background: #007aff;
  font-weight: 600;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  background: #f5f6f7;
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}

.clear-btn {
  color: #007aff;
  font-size: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  color: #999;
  font-size: 22rpx;
}

.batch-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.batch-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.opinion-input {
  background: #f5f6f7;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
  color: #333;
}

.batch-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
}

.btn-approve {
  flex: 1;
  background: #11998e;
  color: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.btn-reject {
  flex: 1;
  background: #ff4d4f;
  color: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.btn-clear {
  width: 160rpx;
  background: #fff;
  color: #666;
  border: 1px solid #ddd;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.list-scroll {
  max-height: calc(100vh - 380rpx);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.left {
  display: flex;
  flex-direction: column;
  max-width: 520rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-0 { color: #F2994A; background: #FFF7E6; }
.status-1 { color: #11998e; background: #e0fcf4; }
.status-2 { color: #ff4d4f; background: #fff1f0; }
.status-3 { color: #999; background: #f5f5f5; }
.status-4 { color: #999; background: #f5f5f5; }
.status-5 { color: #999; background: #f5f5f5; }

.row {
  display: flex;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.row-label {
  width: 90rpx;
  color: #999;
}

.row-value {
  flex: 1;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1px solid #f3f3f3;
}

.check {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #666;
  font-size: 24rpx;
}

.quick-actions {
  display: flex;
  gap: 12rpx;
}

.btn-mini-approve {
  background: rgba(17,153,142,0.12);
  color: #11998e;
  border: 1px solid rgba(17,153,142,0.25);
  font-size: 24rpx;
}

.btn-mini-reject {
  background: rgba(255,77,79,0.10);
  color: #ff4d4f;
  border: 1px solid rgba(255,77,79,0.22);
  font-size: 24rpx;
}

.loading-tip {
  text-align: center;
  color: #999;
  padding: 20rpx 0;
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* 管理端自定义底部菜单栏 */
