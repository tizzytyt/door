.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge {
  background: rgba(255, 59, 48, 0.10);
  border: 1px solid rgba(255, 59, 48, 0.25);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #ff3b30;
  font-weight: 600;
}

.btn-mini {
  background: rgba(0,122,255,0.08);
  color: #007aff;
  border: 1px solid rgba(0,122,255,0.25);
  border-radius: 999rpx;
  font-size: 22rpx;
}

.list-scroll {
  max-height: calc(100vh - 120rpx);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: 18rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.left {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff3b30;
  flex: 0 0 auto;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  max-width: 520rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.status.unread {
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.10);
}

.status.read {
  color: #34c759;
  background: rgba(52, 199, 89, 0.10);
}

.preview {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 26rpx;
}

