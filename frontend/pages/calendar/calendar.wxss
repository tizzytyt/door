.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 20rpx;
  box-sizing: border-box;
}

.calendar-card,
.list-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.month-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.month-btn {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #007aff;
  font-size: 36rpx;
  white-space: nowrap;
}

.week-row {
  display: flex;
  margin-bottom: 10rpx;
}

.week-item {
  flex: 1;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.day-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: 14.2857%;
  height: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  font-size: 26rpx;
  color: #333;
}

.day-item.empty {
  color: transparent;
}

.day-item.selected {
  background: #e6f2ff;
  border-radius: 12rpx;
  color: #007aff;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background: #ff4d4f;
  border-radius: 50%;
  position: absolute;
  bottom: 12rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.reservation-item {
  padding: 18rpx 0;
  border-bottom: 1px solid #f3f3f3;
}

.reservation-item:last-child {
  border-bottom: none;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.device-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time,
.reason {
  display: block;
  color: #666;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-0 { color: #F2994A; background: #FFF7E6; }
.status-1 { color: #11998e; background: #e0fcf4; }
.status-2 { color: #ff4d4f; background: #fff1f0; }
.status-3 { color: #999; background: #f5f5f5; }
.status-4 { color: #999; background: #f5f5f5; }
.status-5 { color: #999; background: #f5f5f5; }

.empty-tip {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

